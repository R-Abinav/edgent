#thresholds
FREE_RAM_THRESHOLD_MB=512
FREE_CPU_THRESHOLD_PERCENT=85

#role -> provider or requester
ROLE=provider

#axl config
AXL_CONFIG_PATH=./node-config-a.json
AXL_API_PORT=9002

#daemon config
DAEMON_PORT=3001

#ollama config
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=tinyllama

#wallet config
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_WALLET_ADDRESS=0x..
REQUESTER_WALLET_ADDRESS=0x...
PROVIDER_WALLET_ADDRESS=0x...


#contract addr
ESCROW_CONTRACT_ADDR=0x

#keeperhub config
KEEPERHUB_WEBHOOK_URL=
KEEPERHUB_TOKEN=

#ens
ENS_NAME=my-node.edgent.eth
ENS_RPC_URL=https://ethereum-rpc.publicnode.com

#payment
PRICE_PER_JOB=0.01
CHAIN=base-sepolia

#test-net
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

